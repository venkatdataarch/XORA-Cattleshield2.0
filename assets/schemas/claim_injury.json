{
  "id": "claim_injury_v1",
  "formType": "claim_injury",
  "version": "1.0",
  "title": "UIIC Livestock Injury / Disease Claim Form",
  "animalTypes": ["cow", "buffalo", "mule", "horse", "donkey"],
  "sections": [
    {
      "id": "policy_reference",
      "title": "Section 1 - Policy Reference",
      "description": "Policy and insured details (pre-filled from policy)",
      "fields": [
        {
          "key": "policy_number",
          "label": "Policy Number",
          "type": "text",
          "required": true,
          "readOnly": true
        },
        {
          "key": "claim_number",
          "label": "Claim Number",
          "type": "text",
          "required": false,
          "readOnly": true
        },
        {
          "key": "insured_name",
          "label": "Name of Insured",
          "type": "text",
          "required": true,
          "readOnly": true
        },
        {
          "key": "address",
          "label": "Address of Insured",
          "type": "textarea",
          "required": true,
          "readOnly": true
        }
      ]
    },
    {
      "id": "animal_details",
      "title": "Section 2 - Animal Details",
      "description": "Details of the insured animal (pre-filled from policy)",
      "fields": [
        {
          "key": "animal_description",
          "label": "Description of Animal",
          "type": "text",
          "required": true,
          "readOnly": true
        },
        {
          "key": "identification_tag",
          "label": "Ear Tag / Identification Number",
          "type": "text",
          "required": true,
          "readOnly": true
        },
        {
          "key": "species_breed",
          "label": "Species / Breed",
          "type": "text",
          "required": true,
          "readOnly": true
        },
        {
          "key": "sex",
          "label": "Sex",
          "type": "text",
          "required": true,
          "readOnly": true
        },
        {
          "key": "color",
          "label": "Colour",
          "type": "text",
          "required": true,
          "readOnly": true
        },
        {
          "key": "age",
          "label": "Age",
          "type": "text",
          "required": true,
          "readOnly": true
        },
        {
          "key": "value_prior_to_injury",
          "label": "Value of Animal Prior to Injury/Disease",
          "type": "currency",
          "required": true,
          "hint": "Estimated market value before the incident"
        }
      ]
    },
    {
      "id": "injury_details",
      "title": "Section 3 - Injury / Disease Details",
      "description": "Details of the injury or disease affecting the animal",
      "fields": [
        {
          "key": "nature_of_injury",
          "label": "Nature of Injury / Disease",
          "type": "textarea",
          "required": true,
          "hint": "Describe the type and nature of injury or disease"
        },
        {
          "key": "injury_date",
          "label": "Date Injury / Disease First Noticed",
          "type": "date",
          "required": true
        },
        {
          "key": "injury_duration",
          "label": "Duration of Injury / Disease",
          "type": "text",
          "required": true,
          "hint": "e.g. 10 days, 2 weeks, ongoing"
        },
        {
          "key": "permanent_incapacity",
          "label": "Is There Permanent Incapacity?",
          "type": "radio",
          "required": true,
          "options": ["Yes", "No"]
        },
        {
          "key": "incapacity_type",
          "label": "Type of Permanent Incapacity",
          "type": "dropdown",
          "required": true,
          "options": ["Cannot conceive", "Cannot yield milk", "Cannot breed", "Cannot work / bear load", "Other"],
          "showWhen": { "field": "permanent_incapacity", "value": "Yes" }
        },
        {
          "key": "incapacity_details",
          "label": "Details of Incapacity",
          "type": "textarea",
          "required": true,
          "hint": "Describe the nature and extent of incapacity",
          "showWhen": { "field": "permanent_incapacity", "value": "Yes" }
        },
        {
          "key": "steps_to_prevent_incapacity",
          "label": "Steps Taken to Prevent Incapacity",
          "type": "textarea",
          "required": true,
          "hint": "What treatment / measures were taken?"
        },
        {
          "key": "treatment_given",
          "label": "Treatment Given",
          "type": "textarea",
          "required": true,
          "hint": "Describe the veterinary treatment provided"
        },
        {
          "key": "current_condition",
          "label": "Current Condition of Animal",
          "type": "textarea",
          "required": true,
          "hint": "Describe the animal's present state of health"
        },
        {
          "key": "vet_name",
          "label": "Name of Treating Veterinary Doctor",
          "type": "text",
          "required": true
        },
        {
          "key": "vet_address",
          "label": "Address of Veterinary Doctor",
          "type": "textarea",
          "required": true
        },
        {
          "key": "claim_amount",
          "label": "Claim Amount Sought",
          "type": "currency",
          "required": true,
          "validation": { "min": 1, "errorMessage": "Claim amount must be greater than zero" }
        }
      ]
    },
    {
      "id": "other_details",
      "title": "Section 4 - Other Details",
      "fields": [
        {
          "key": "insured_elsewhere",
          "label": "Is the Animal Insured Elsewhere?",
          "type": "radio",
          "required": true,
          "options": ["Yes", "No"]
        },
        {
          "key": "other_insurer",
          "label": "Name of Other Insurer",
          "type": "text",
          "required": true,
          "showWhen": { "field": "insured_elsewhere", "value": "Yes" }
        },
        {
          "key": "other_policy_number",
          "label": "Other Policy Number",
          "type": "text",
          "required": false,
          "showWhen": { "field": "insured_elsewhere", "value": "Yes" }
        },
        {
          "key": "ear_tag_enclosed",
          "label": "Is the Ear Tag Available for Verification?",
          "type": "radio",
          "required": true,
          "options": ["Yes", "No"]
        },
        {
          "key": "premium_paid_date",
          "label": "Date Premium Was Paid",
          "type": "date",
          "required": true
        }
      ]
    }
  ]
}
